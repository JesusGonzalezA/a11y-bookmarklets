{
  "name": "@bookmarklets-a11y/build-tools",
  "version": "0.1.0",
  "description": "Build tooling: compile TypeScript bookmarklets into javascript: URLs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "build-bookmarklets": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "glob": "^11.0.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
