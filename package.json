{
  "name": "bookmarklets-a11y",
  "version": "0.1.0",
  "private": true,
  "description": "Accessibility bookmarklets for humans and AI agents",
  "type": "module",
  "workspaces": [
    "packages/bookmarklets",
    "packages/website"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:bookmarklets": "npm run build:bookmarklets -w packages/bookmarklets",
    "dev": "npm run build:bookmarklets && npm run dev -w packages/website",
    "test": "vitest run",
    "clean": "rm -rf packages/*/dist packages/*/dist-build dist",
    "lint": "biome check .",
    "format": "biome format . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@swc/core": "^1.15.18",
    "@types/node": "^25.3.3",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "bookmarklet",
    "audit",
    "wcag",
    "mcp",
    "ai"
  ],
  "author": "",
  "license": "MIT"
}
